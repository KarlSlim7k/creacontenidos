    "check:api": "node scripts/check-public-api.js",
    "check:leads": "node scripts/check-leads.js",
    "check:e2e": "node scripts/verify-e2e.js",
    "check:admin": "node scripts/check-admin-api.js",
    "check:social": "node scripts/check-social.js",
    "check:content": "node scripts/check-content-engine.js",
    "check:newsletter": "node scripts/check-newsletter.js",
    "check:nota-ssr": "node scripts/check-nota-ssr.js",
    "check:scraper": "node scripts/check-competitor-scraper.js",
