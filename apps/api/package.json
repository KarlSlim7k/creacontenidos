{
  "name": "crea-command-center-api",
  "version": "0.1.0",
  "description": "Backend de CREA Command Center: listening, content-engine, editorial, distribution",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
