# Base de datos
DATABASE_URL=

# APIs de IA
OPENROUTER_API_KEY=
AI_MODEL_IMAGE=google/gemini-3-pro-image
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Social listening — Apify Cloud (fase posterior, alternativa al scraper local)
APIFY_API_TOKEN=

# Competitor scraper (apps/competitor-scraper/) — opcional.
# Vacío = el endpoint /api/listening/competitors/detect cae a Perplexity.
# Definir cuando el servicio esté corriendo en la red de Dokploy:
#   COMPETITOR_SCRAPER_URL=http://competitor-scraper:3015
COMPETITOR_SCRAPER_URL=

# Newsletter "Buenos días, Perote"
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM=Buenos días, Perote <hola@crea-contenidos.com>

# Contacto (solo display/mailto hasta verificar el dominio en Resend)
CONTACT_EMAIL=contacto@crea-contenidos.com
COMUNIDAD_EMAIL=comunidad@crea-contenidos.com

# Nous Portal (RADAR, propuestas, borradores, QA)
NOUS_PORTAL_API_KEY=
AI_MODEL_DEFAULT=deepseek/deepseek-v4-flash
AI_MODEL_COMPLEX=minimax/minimax-m3
AI_MODEL_QA=openai/gpt-5-nano

# Distribución (push tras publicar; sin credenciales el canal aparece "no configurado")
PUBLIC_SITE_URL=https://crea-contenidos.com
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
WORDPRESS_URL=
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=

# Auth
JWT_SECRET=

# Servidor
PORT=3000
NODE_ENV=development

# CORS: vacío = abierto (dev; el portal corre en :4000 y la API en :3000).
# En producción, orígenes permitidos separados por comas, p. ej. https://creacontenidos.mx
CORS_ORIGIN=
