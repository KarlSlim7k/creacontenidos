---
// Puede haber 2-3 instancias en una misma página (topbar, menú móvil, pie de
// nota) — el script de abajo usa querySelectorAll y Astro dedupea el bloque
// (mismo contenido) una sola vez por página, así que un solo listener setup
// cubre todas las instancias, igual que initNewsletterForm() en main.js.
interface Props {
  variant?: 'popover' | 'block';
  title?: string;
  idPrefix: string;
}
const { variant = 'block', title, idPrefix } = Astro.props;
---
{variant === 'popover' ? (
  <details class="subscribe-details">
    <summary class="subscribe">SUSCRIBIRSE</summary>
    <form data-newsletter-form class="subscribe-popover">
      <label for={`${idPrefix}-email`} class="visually-hidden">Correo electrónico</label>
      <input id={`${idPrefix}-email`} name="email" type="email" placeholder="tu@correo.com" required maxlength="320" autocomplete="email">
      <div class="field visually-hidden" aria-hidden="true">
        <label for={`${idPrefix}-website`}>Sitio web (no llenar)</label>
        <input id={`${idPrefix}-website`} name="website" type="text" tabindex="-1" autocomplete="off">
      </div>
      <button type="submit" class="btn btn-brand">Suscribirme</button>
      <p data-form-note role="status" aria-live="polite" tabindex="-1"></p>
    </form>
  </details>
) : (
  <form data-newsletter-form class="nl-cta">
    <p class="nl-title">{title || 'Recibe cada mañana "Buenos días, Perote"'}</p>
    <div class="field">
      <label for={`${idPrefix}-email`}>Correo</label>
      <input id={`${idPrefix}-email`} name="email" type="email" placeholder="tu@correo.com" required maxlength="320" autocomplete="email">
    </div>
    <div class="field visually-hidden" aria-hidden="true">
      <label for={`${idPrefix}-website`}>Sitio web (no llenar)</label>
      <input id={`${idPrefix}-website`} name="website" type="text" tabindex="-1" autocomplete="off">
    </div>
    <button type="submit" class="btn btn-brand">Suscribirme</button>
    <p data-form-note role="status" aria-live="polite" tabindex="-1" style="font-size:12px;color:var(--brand);margin-top:12px;outline:none;"></p>
  </form>
)}

<script>
  function setNote(form: HTMLFormElement, text: string, kind: 'ok' | 'error') {
    const note = form.querySelector<HTMLElement>('[data-form-note]');
    if (!note) return;
    note.textContent = text;
    note.style.color = kind === 'error' ? 'var(--accent)' : 'var(--brand)';
    note.focus();
  }

  document.querySelectorAll<HTMLFormElement>('form[data-newsletter-form]').forEach((form) => {
    const details = form.closest('details');
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (submitBtn) submitBtn.disabled = true;
      setNote(form, 'Enviando…', 'ok');
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const website = (form.elements.namedItem('website') as HTMLInputElement).value;
      fetch('/api/public/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, website }),
      })
        .then((res) => {
          if (res.status === 201 || res.status === 200) {
            form.reset();
            setNote(form, 'Te enviamos un correo para confirmar tu suscripción. Revisa tu bandeja.', 'ok');
            if (details) setTimeout(() => { details.open = false; }, 3500);
            return;
          }
          if (res.status === 429) {
            setNote(form, 'Has enviado demasiadas solicitudes en poco tiempo. Espera unos minutos e inténtalo de nuevo.', 'error');
            return;
          }
          return res.json().then((body) => {
            const fields = body && body.fields ? Object.keys(body.fields).join(', ') : '';
            setNote(form, 'No pudimos enviar el formulario. Revisa los campos' + (fields ? ' (' + fields + ')' : '') + ' e inténtalo de nuevo.', 'error');
          });
        })
        .catch(() => setNote(form, 'No pudimos conectar con el servidor. Inténtalo de nuevo más tarde.', 'error'))
        .finally(() => { if (submitBtn) submitBtn.disabled = false; });
    });
  });
</script>
