---
// Puerto de las tarjetas de renderHomePage() (main.js): "hero" = las 4 de portada
// (la primera featured y con dek+byline), "grid" = las de cada section-block.
import Cover from './Cover.astro';
import type { Article } from '../lib/api';
import { notaHref } from '../lib/format';
import { timeAgo } from '../lib/format';

interface Props {
  article: Article;
  variant: 'hero' | 'grid';
  featured?: boolean;
}
const { article: a, variant, featured = false } = Astro.props;
const href = notaHref(a.slug);
---
{variant === 'hero' ? (
  <article>
    <a href={href}>
      <Cover coverUrl={a.cover_image_url} section={a.section} class={`ratio-4-3${featured ? ' featured' : ''}`} style="margin-bottom:10px;" eager={featured} />
      <div class="eyebrow" style="margin-bottom:6px;">{a.section.toUpperCase()}</div>
      <h2 class="card-title" style="font-size:17px;line-height:1.3;margin-bottom:6px;">{a.title}</h2>
    </a>
    <p class="card-dek" style="margin-bottom:8px;">{a.dek}</p>
    <div class="card-byline">Por {a.author_name} &middot; {timeAgo(a.published_at)}</div>
  </article>
) : (
  <article>
    <a href={href}><Cover coverUrl={a.cover_image_url} section={a.section} class="ratio-4-3" style="margin-bottom:8px;" /></a>
    <div class="eyebrow" style="margin-bottom:5px;">{a.section.toUpperCase()}</div>
    <h3 class="card-title" style="font-size:13px;margin-bottom:5px;font-weight:500;"><a href={href}>{a.title}</a></h3>
    <p class="card-dek">{a.dek}</p>
  </article>
)}
