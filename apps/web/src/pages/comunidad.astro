---
import EditorialLayout from '../layouts/EditorialLayout.astro';
import MobileMenu from '../components/MobileMenu.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import LeadForm from '../components/LeadForm.astro';
import FooterEditorial from '../components/editorial/FooterEditorial.astro';
import { creaApi, type Author } from '../lib/api';
import { perfilHref } from '../lib/format';
import { SECTIONS } from '../lib/sections';

let authors: Author[] = [];
try {
  authors = await creaApi<Author[]>('/api/public/authors');
} catch {
  authors = [];
}
---
<EditorialLayout title="Comunidad" description="Cuéntanos lo que pasa en tu colonia, tu pueblo o tu negocio. La comunidad también hace CREA Contenidos.">
  <Fragment slot="mobile-menu">
    <MobileMenu />
  </Fragment>

  <main class="container" style="padding-top:32px;padding-bottom:8px;">
    <div class="eyebrow" style="margin-bottom:8px;">COMUNIDAD</div>
    <h1 style="font-size:32px;margin:0 0 10px;max-width:560px;">Cuéntanos lo que pasa en tu colonia, tu pueblo o tu negocio</h1>
    <p class="card-dek" style="font-size:14px;line-height:1.6;margin:0 0 28px;max-width:560px;">CREA se sostiene de su comunidad. Si vives en Perote o el corredor Perote&ndash;Xalapa&ndash;Puebla y tienes una idea, un tema o un evento que merece cobertura, escríbenos.</p>
  </main>

  <div class="container" style="padding-bottom:28px;">
    <div class="grid grid-2" style="gap:36px;">
      <div>
        <div class="eyebrow" style="margin-bottom:14px;">ENVÍA TU IDEA</div>
        <LeadForm variant="comunidad" chipOptions={[...SECTIONS]} />
      </div>
      <div>
        <NewsletterForm idPrefix="nl-comunidad" />

        <div class="eyebrow" style="margin-bottom:14px;">COLABORADORES ACTIVOS</div>
        <div>
          {authors.length === 0 ? null : authors.map((a) => {
            const init = a.author_name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();
            const sectionsText = (a.sections || []).slice(0, 2).join(' y ');
            return (
              <a href={perfilHref(a.author_name)} style="display:flex;gap:12px;align-items:center;padding:12px 0;border-bottom:0.5px solid var(--line);">
                <div class="avatar" style="width:38px;height:38px;"><span style="font-size:12px;">{init}</span></div>
                <div>
                  <p style="font-size:13px;font-weight:500;margin:0 0 2px;">{a.author_name}</p>
                  <p style="font-size:11px;color:var(--text-mute);margin:0;">{sectionsText}</p>
                </div>
              </a>
            );
          })}
        </div>

        <div class="eyebrow" style="margin:24px 0 12px;">&iquest;PREFIERES ESCRIBIRNOS DIRECTO?</div>
        <p style="font-size:13px;margin:0 0 24px;"><a href="mailto:comunidad@crea-contenidos.com" style="color:var(--brand);text-decoration:underline;">comunidad@crea-contenidos.com</a></p>

        <div class="eyebrow" style="margin:0 0 12px;">ZONA DE COBERTURA</div>
        <div class="img-ph" style="aspect-ratio:16/7;margin-bottom:12px;"><span class="cap">mapa del corredor Perote&ndash;Xalapa&ndash;Puebla</span></div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          {['Perote', 'Xalapa', 'Puebla', 'Las Vigas', 'Altotonga', 'Tenextepec'].map((c) => (
            <span class="chip" style="background:var(--bg-3);color:var(--brand);border-color:transparent;">{c}</span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="footer">
    <FooterEditorial links={[
      { href: '/', label: 'Home' },
      { href: '/producciones', label: 'Producciones CREA' },
      { href: '/estudio/media-kit', label: 'Media kit' },
      { href: '/estudio/contacto', label: 'Contacto' },
    ]} />
  </Fragment>
</EditorialLayout>
