---
import EstudioLayout from '../../layouts/EstudioLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const interes = Astro.url.searchParams.get('interes') || undefined;
const CHIP_OPTIONS = ['Patrocinio de sección', 'Branded content', 'Tercer Tiempo', 'Publicidad display', 'Otro'];
---
<EstudioLayout
  title="Contacto comercial"
  description="Contacto comercial del Estudio CREA. Cuéntanos qué necesita tu marca y el equipo te responde en menos de 48 horas."
  active="contacto"
>
  <main class="container" style="padding-top:30px;padding-bottom:30px;">
    <div class="eyebrow" style="margin-bottom:10px;">CONTACTO COMERCIAL</div>
    <h1 style="font-size:30px;margin:0 0 8px;">Hablemos de tu marca</h1>
    <p class="card-dek" style="font-size:13px;margin:0 0 28px;max-width:480px;">Cuéntanos qué necesitas y un miembro del equipo comercial te responde en menos de 48 horas.</p>

    <div class="grid grid-2" style="gap:36px;">
      <LeadForm variant="estudio-contacto" chipOptions={CHIP_OPTIONS} initialInterest={interes} />
      <div>
        <div class="panel" style="margin-bottom:16px;">
          <div class="eyebrow" style="color:var(--text-mute);margin-bottom:14px;">CONTACTO DIRECTO</div>
          <p style="font-size:13px;margin:0 0 4px;">Comercial: <a href="mailto:estudio@crea-contenidos.com" style="color:inherit;">estudio@crea-contenidos.com</a></p>
          <p style="font-size:13px;margin:0 0 8px;">General: <a href="mailto:contacto@crea-contenidos.com" style="color:inherit;">contacto@crea-contenidos.com</a></p>
          <p style="font-size:12px;color:var(--text-mute);margin:0;">Perote, Veracruz &middot; respuesta en menos de 48 horas</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <a href="/estudio/media-kit" style="font-size:12px;color:var(--brand);text-decoration:underline;">Ver media kit</a>
          <a href="/estudio/servicios" style="font-size:12px;color:var(--brand);text-decoration:underline;">Ver catálogo de servicios</a>
        </div>
      </div>
    </div>
  </main>
</EstudioLayout>
