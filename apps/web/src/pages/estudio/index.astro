---
import EstudioLayout from '../../layouts/EstudioLayout.astro';
import StatCards from '../../components/estudio/StatCards.astro';
import { creaApi, getSponsors, type SiteMetrics } from '../../lib/api';
import { notaHref } from '../../lib/format';

let metrics: SiteMetrics | null = null;
try {
  metrics = await creaApi<SiteMetrics>('/api/public/site-metrics');
} catch {
  metrics = null;
}
const sponsors = await getSponsors();
---
<EstudioLayout title="Estudio CREA · Producción, campañas y medios propios" description="Patrocinios, branded content y producción audiovisual para negocios del corredor Perote–Xalapa–Puebla, con el respaldo editorial de CREA.">
  <main class="container" style="padding-top:30px;padding-bottom:28px;">
    <div class="eyebrow" style="margin-bottom:12px;">PRODUCCIÓN, CAMPAÑAS Y MEDIOS PROPIOS</div>
    <h1 style="font-size:32px;line-height:1.15;margin:0 0 16px;max-width:540px;">Tu marca, contada con el alcance editorial de CREA</h1>
    <p style="font-size:15px;color:var(--text-mute);line-height:1.6;margin:0 0 22px;max-width:480px;">Patrocinios, branded content y producción audiovisual para negocios del corredor Perote &middot; Xalapa &middot; Puebla, respaldados por una audiencia que ya confía en nuestra cobertura.</p>
    <div style="display:flex;gap:12px;flex-wrap:wrap;">
      <a href="/estudio/contacto" class="btn btn-accent">Hablar con ventas</a>
      <a href="/estudio/media-kit" class="btn btn-outline">Descargar media kit</a>
    </div>
  </main>

  <div class="container">
    <StatCards metrics={metrics} activeBrands={sponsors.length} />

    <div style="margin-bottom:28px;">
      <div class="eyebrow" style="color:var(--text-mute);margin-bottom:16px;">MARCAS QUE YA CONFÍAN EN CREA</div>
      {sponsors.length > 0 && (
        <>
          <div class="grid grid-4" style="margin-bottom:16px;">
            {sponsors.slice(0, 4).map((a) => (
              <div class="panel" style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:14px 10px;">
                <div style="width:26px;height:26px;border-radius:6px;background:var(--bg-3);"></div>
                <span style="font-size:10px;color:var(--text-mute);text-align:center;">{a.sponsor_name}</span>
              </div>
            ))}
          </div>
          <div class="grid grid-2">
            {sponsors.slice(0, 2).map((a) => (
              <a class="testimonial-card" href={notaHref(a.slug)} style="display:block;">
                <p class="quote">{a.title}</p>
                <p class="who">{a.sponsor_name} &middot; Contenido patrocinado en {a.section}</p>
              </a>
            ))}
          </div>
        </>
      )}
    </div>

    <div class="eyebrow" style="color:var(--text-mute);margin-bottom:14px;">LO QUE OFRECEMOS</div>
    <div class="grid grid-2" style="margin-bottom:26px;">
      <a href="/estudio/servicios" class="panel">
        <div style="width:10px;height:10px;border-radius:2px;background:var(--accent);margin-bottom:14px;"></div>
        <p style="font-size:15px;font-weight:500;color:var(--text);margin:0 0 6px;">Campañas y patrocinios</p>
        <p style="font-size:12px;color:var(--text-mute);line-height:1.5;margin:0;">Presencia de marca integrada al flujo editorial, por sección o por temporada.</p>
      </a>
      <a href="/estudio/servicios" class="panel">
        <div style="width:10px;height:10px;border-radius:2px;background:var(--accent);margin-bottom:14px;"></div>
        <p style="font-size:15px;font-weight:500;color:var(--text);margin:0 0 6px;">Publicidad en sitio</p>
        <p style="font-size:12px;color:var(--text-mute);line-height:1.5;margin:0;">Espacios medidos en crea-contenidos.com con reportes de desempeño.</p>
      </a>
      <a href="/estudio/servicios" class="panel">
        <div style="width:10px;height:10px;border-radius:2px;background:var(--accent);margin-bottom:14px;"></div>
        <p style="font-size:15px;font-weight:500;color:var(--text);margin:0 0 6px;">Producción audiovisual</p>
        <p style="font-size:12px;color:var(--text-mute);line-height:1.5;margin:0;">Video, podcast y branded content producido por el equipo CREA.</p>
      </a>
      <a href="/estudio/tercer-tiempo" class="panel">
        <div style="width:10px;height:10px;border-radius:2px;background:var(--brand);margin-bottom:14px;"></div>
        <p style="font-size:15px;font-weight:500;color:var(--text);margin:0 0 6px;">Programas propios</p>
        <p style="font-size:12px;color:var(--text-mute);line-height:1.5;margin:0;">Pauta dentro de Tercer Tiempo y futuros formatos originales de CREA.</p>
      </a>
    </div>

    <div class="panel" style="margin-bottom:24px;padding:28px 32px;">
      <div class="grid grid-2" style="align-items:center;">
        <div>
          <h2 style="font-size:24px;margin:0 0 10px;">Hagamos crecer tu negocio en Perote y la región</h2>
          <p style="font-size:13px;color:var(--text-mute);line-height:1.6;margin:0 0 18px;max-width:420px;">No solo vendemos espacio publicitario: te acompañamos con estrategia de publicidad y marketing hecha a la medida de tu negocio local.</p>
          <a href="/estudio/contacto" class="btn btn-accent">Quiero hacer crecer mi negocio</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div style="display:flex;gap:12px;align-items:center;">
            <div class="avatar" style="width:30px;height:30px;background:var(--bg);border:0.5px solid var(--line);"><span style="font-size:11px;color:var(--brand);">01</span></div>
            <span style="font-size:13px;font-weight:500;">Diagnóstico de tu negocio</span>
          </div>
          <div style="display:flex;gap:12px;align-items:center;">
            <div class="avatar" style="width:30px;height:30px;background:var(--bg);border:0.5px solid var(--line);"><span style="font-size:11px;color:var(--brand);">02</span></div>
            <span style="font-size:13px;font-weight:500;">Plan de contenido y pauta</span>
          </div>
          <div style="display:flex;gap:12px;align-items:center;">
            <div class="avatar" style="width:30px;height:30px;background:var(--bg);border:0.5px solid var(--line);"><span style="font-size:11px;color:var(--brand);">03</span></div>
            <span style="font-size:13px;font-weight:500;">Resultados medibles cada mes</span>
          </div>
        </div>
      </div>
    </div>

    <a href="/estudio/tercer-tiempo" style="margin:0 0 24px;background:var(--brand-bg);border-radius:10px;padding:20px;display:flex;gap:18px;align-items:center;border:0.5px solid var(--line);">
      <div style="width:56px;height:56px;border-radius:8px;background:var(--bg-3);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span style="font-family:var(--font-display);font-weight:700;color:var(--brand);font-size:18px;">TT</span>
      </div>
      <div style="flex:1;">
        <div class="eyebrow" style="color:var(--brand);margin-bottom:4px;">PROGRAMA PROPIO CREA</div>
        <p style="font-size:15px;font-weight:500;color:var(--text);margin:0 0 4px;">Tercer Tiempo</p>
        <p style="font-size:12px;color:var(--text-mute);margin:0;">Deportes y comunidad, en vivo cada semana. Espacios de patrocinio disponibles.</p>
      </div>
      <span class="btn btn-outline" style="white-space:nowrap;">Ver paquetes</span>
    </a>

    <div class="panel" style="margin-bottom:28px;display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;">
      <div>
        <p style="font-size:16px;font-weight:500;color:var(--text);margin:0 0 4px;">&iquest;Listos para contar tu historia?</p>
        <p style="font-size:12px;color:var(--text-mute);margin:0;">Respuesta en menos de 48 horas.</p>
      </div>
      <a href="/estudio/contacto" class="btn btn-accent">Escríbenos</a>
    </div>
  </div>
</EstudioLayout>
