# Variables para docker-compose.yml. Copiar a .env y completar (o pegar en el
# tab "Environment" de Dokploy — ahí es donde debe vivir esto en producción).
# .env NO se sube al repo (ver .gitignore).
POSTGRES_USER=crea
POSTGRES_PASSWORD=
POSTGRES_DB=crea_command_center

# Secrets del servicio api (ver apps/api/.env.example para detalle de cada uno)
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
APIFY_API_TOKEN=
# Firecrawl (RADAR web pública; ver apps/api/.env.example y docs/ia/firecrawl-integracion.md)
FIRECRAWL_API_KEY=
# CSV de portadas regionales (Perote / Xalapa / Veracruz). ~5–6 URLs: cupo Free ~1000/mes
# (cron 6h × N URLs). Alternativas OK: https://www.alcalorpolitico.com/,https://www.xeu.mx/,https://www.masnoticias.mx/
FIRECRAWL_SOURCE_URLS=https://www.diariodexalapa.com.mx/,https://www.eldictamen.mx/,https://www.avcnoticias.com.mx/,https://formato7.com/,https://lasillarota.com/veracruz,https://perote.gob.mx/
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM=Buenos días, Perote <hola@crea-contenidos.com>
CONTACT_EMAIL=contacto@crea-contenidos.com
COMUNIDAD_EMAIL=comunidad@crea-contenidos.com
NOUS_PORTAL_API_KEY=
AI_MODEL_DEFAULT=deepseek/deepseek-v4-flash
AI_MODEL_COMPLEX=minimax/minimax-m3
AI_MODEL_QA=openai/gpt-5-nano
JWT_SECRET=
CORS_ORIGIN=
